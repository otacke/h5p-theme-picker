{
  "name": "h5p-theme-picker",
  "version": "0.0.10",
  "description": "Web component for setting theme for H5P",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otacke/h5p-theme-picker.git"
  },
  "scripts": {
    "lint": "stylelint './src/**/*.css' && eslint './src/**/*.js'",
    "build": "webpack --mode=production",
    "watch": "webpack --mode=development --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "H5P",
    "theme"
  ],
  "license": "MIT",
  "author": "Oliver Tacke",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": true,
  "dependencies": {
    "@oddbird/css-anchor-positioning": "^0.9.0",
    "color": "^5.0.3"
  },
  "devDependencies": {
    "css-loader": "^7.1.4",
    "cssnano": "^7.1.4",
    "eslint-config-snordian-h5p": "github:otacke/eslint-config-snordian-h5p",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended": "^18.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
